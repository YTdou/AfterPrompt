{
  "name": "last-mile-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A source-first visual editor for AI-generated HTML, slides, and SVG.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "check": "npm test && npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:browser": "node scripts/browser-smoke.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cli": "node --import tsx src/cli/index.ts"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "codemirror": "^6.0.2",
    "jsdom": "^26.1.0",
    "jszip": "^3.10.1",
    "moveable": "^0.53.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.3",
    "playwright-core": "^1.55.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
